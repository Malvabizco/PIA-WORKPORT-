<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/input_background"/>
            <stroke android:width="2dp" android:color="@color/input_stroke_focused"/>
            <corners android:radius="12dp"/>
            <padding android:left="16dp" android:right="16dp" android:top="12dp" android:bottom="12dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/input_background"/>
            <stroke android:width="1dp" android:color="@color/input_stroke"/>
            <corners android:radius="12dp"/>
            <padding android:left="16dp" android:right="16dp" android:top="12dp" android:bottom="12dp"/>
        </shape>
    </item>
</selector>